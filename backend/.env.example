# ── Server ─────────────────────────────────────────────────────────────────
# ENV=production disables auto-reload and enables multi-worker mode in run.sh
ENV=dev
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Scan limits ─────────────────────────────────────────────────────────────
# Max scans running at once (requests beyond this get HTTP 429)
MAX_CONCURRENT_SCANS=3
# Hard timeout for a full scan / exam analysis pipeline (seconds)
SCAN_TIMEOUT_SECS=600
ANALYSIS_TIMEOUT_SECS=300
# Finished scans/sessions are purged from memory after this many seconds
SESSION_TTL_SECS=86400
# Set to true ONLY for lab/demo use — allows scanning localhost/private IPs
ALLOW_PRIVATE_TARGETS=false

# ── Groq (primary LLM — fast cloud inference) ─────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (offline / low-spec fallback) ──────────────────────────────────
# Install: https://ollama.com/download
# Ollama runs automatically on port 11434 — no extra config needed.
OLLAMA_BASE_URL=http://localhost:11434

# System-aware model routing (auto-detected — no action required)
# The router detects RAM / CPU cores / GPU and selects a model automatically:
#   low  spec (RAM < 8 GB  OR cores < 4)  → phi3:mini   (~2.3 GB)
#   mid  spec (RAM 8-16 GB AND cores 4+)  → llama3.2    (~2 GB)
#   high spec (RAM >= 16 GB AND cores 8+) → llama3.1:8b (~5 GB)
#
# Override the model for a specific tier:
OLLAMA_MODEL_LOW=phi3:mini
OLLAMA_MODEL_MID=llama3.2
OLLAMA_MODEL_HIGH=llama3.1:8b
#
# Override ALL tiers (backward-compatible, takes highest precedence):
# OLLAMA_MODEL=llama3.2
#
# Force a spec tier (skip hardware detection):
# SYSTEM_SPEC_OVERRIDE=low
#
# Simulate hardware for testing:
# SYSTEM_RAM_GB=4
# SYSTEM_CPU_CORES=2
# SYSTEM_HAS_GPU=false
