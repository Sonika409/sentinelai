# Frontend → backend wiring. On Vercel, set these in
# Project Settings → Environment Variables (Production).
#
# Point both at your deployed Render backend. Use https:// for the API
# and wss:// for the WebSocket (same host).

NEXT_PUBLIC_API_URL=https://sentinelai-backend.onrender.com
NEXT_PUBLIC_WS_URL=wss://sentinelai-backend.onrender.com

# Local development defaults (no .env needed locally):
#   NEXT_PUBLIC_API_URL=http://localhost:8000
#   NEXT_PUBLIC_WS_URL=ws://localhost:8000
